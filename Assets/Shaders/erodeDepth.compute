*/
	// Not eroded, copy pixel from In
    Result[id.xy] = In[id.xy];
}

[numthreads(128, 1, 1)]
void CopyRGBToOutput(uint3 id : SV_DispatchThreadID)
{
	Result[id.xy] = In[id.xy];

	//Result[id.xy] = uint4(255, 0, 0, 255);

	//if(In[id.xy].x > 0.1f) Result[id.xy] = float4(1,0,0,1);
}
