// Each #kernel tells which function to compile; you can have many kernels
#pragma kernel Erode
#pragma kernel ErodeFull
#pragma kernel CopyRGBToOutput
#pragma kernel Blur

// Create a RenderTexture with enableRandomWrite flag and set it
// with cs.SetTexture
RWTexture2D<float4> Result;
Texture2D<float4> In;

int height;
int width;

bool isBlack(float4 input)
{
    return ((input.x + input.y + input.z) < 0.05f);
}

[numthreads(16, 16, 1)]
void ErodeFull(uint3 id : SV_DispatchThreadID)
{
